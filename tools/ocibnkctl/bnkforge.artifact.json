{
  "schema_version": 1,
  "name": "ocibnkctl-tools-runner",
  "version": "2.3.1.16",
  "kind": "container_image",
  "description": "ocibnkctl tools runner (wraps ocibnkctl v2.3.1-9) \u2014 deploys F5 BIG-IP Next for Kubernetes 2.3.1 on a native k3s cluster whose nodes run as sibling containers on the host OCI runtime, reached through the BNK Forge docker-socket proxy. PoC shape is seeded from OCIBNKCTL_* env at init; argv-only steps, no shell.",
  "container_image": {
    "registry_host": "ghcr.io",
    "repository": "mwiget/ocibnkctl-tools-runner",
    "digest": "sha256:28394ceee400a2c93e1e90fabea28e94e19f58858a59232a9ecd211149ca0004"
  },
  "lifecycle": {
    "supports_apply": true,
    "supports_destroy": true
  },
  "state": {
    "mount_path": "/state",
    "home_env": {
      "DOCKER_HOST": "tcp://docker-socket-proxy-infra:2375"
    }
  },
  "cluster": {
    "name": "{{inputs.poc_name}}",
    "kubeconfig_file": "{{inputs.poc_name}}/artifacts/kubeconfig",
    "cloud_provider": "on-prem"
  },
  "execution": {
    "engine": "container",
    "limits": {
      "cpus": "2",
      "memory": "2g"
    }
  },
  "steps": {
    "init": [
      {
        "name": "init-poc",
        "args": [
          "ocibnkctl",
          "init",
          "{{inputs.poc_name}}",
          "--no-git"
        ],
        "env": {
          "OCIBNKCTL_CUSTOMER": "{{inputs.customer}}",
          "OCIBNKCTL_PROVIDER": "{{inputs.provider}}",
          "OCIBNKCTL_TMM_NODES": "{{inputs.tmm_nodes}}",
          "OCIBNKCTL_EDGE_OCTET": "{{inputs.edge_octet}}",
          "OCIBNKCTL_HOST_PROFILE": "{{inputs.host_profile}}",
          "OCIBNKCTL_TEEMS_RELAY": "{{inputs.teems_relay}}"
        },
        "timeout_seconds": 300,
        "run_once": true
      }
    ],
    "apply": [
      {
        "name": "validate",
        "args": [
          "ocibnkctl",
          "validate",
          "--poc",
          "/state/{{inputs.poc_name}}"
        ],
        "timeout_seconds": 300
      },
      {
        "name": "e2e",
        "args": [
          "ocibnkctl",
          "e2e",
          "--poc",
          "/state/{{inputs.poc_name}}",
          "--yolo",
          "--confirm-cluster",
          "{{inputs.poc_name}}"
        ],
        "timeout_seconds": 5400,
        "retry": {
          "max_attempts": 2,
          "backoff_seconds": 120
        }
      }
    ],
    "destroy": [
      {
        "name": "destroy",
        "args": [
          "ocibnkctl",
          "destroy",
          "--poc",
          "/state/{{inputs.poc_name}}",
          "--yolo",
          "--confirm-cluster",
          "{{inputs.poc_name}}"
        ],
        "timeout_seconds": 1800
      }
    ]
  },
  "inputs": {
    "required": [
      {
        "name": "poc_name",
        "type": "string",
        "source": "user",
        "default": "poc",
        "description": "PoC/cluster name ([a-z0-9-]). Also names the k3s node containers \u2014 give parallel PoCs on one host distinct names."
      }
    ],
    "optional": [
      {
        "name": "provider",
        "type": "string",
        "source": "user",
        "default": "docker",
        "description": "Host container runtime the k3s nodes run on."
      },
      {
        "name": "tmm_nodes",
        "type": "number",
        "source": "user",
        "default": 1,
        "description": "Worker nodes dedicated to TMM (one active TMM pod each)."
      },
      {
        "name": "edge_octet",
        "type": "number",
        "source": "user",
        "default": 99,
        "description": "3rd octet of the bnk-edge network (192.168.<n>.0/24). Distinct per parallel cluster."
      },
      {
        "name": "host_profile",
        "type": "string",
        "source": "user",
        "default": "",
        "description": "Blank = auto-detect from host cores; 'small' sheds TMM's metrics sidecar."
      },
      {
        "name": "teems_relay",
        "type": "boolean",
        "source": "user",
        "default": false,
        "description": "Host-side TEEMS egress relay for hosts with lossy forwarded egress."
      },
      {
        "name": "customer",
        "type": "string",
        "source": "user",
        "default": "",
        "description": "Optional label recorded in poc.yaml metadata."
      }
    ]
  },
  "references": [],
  "secret_files": [
    {
      "secret_name": "far_tarball",
      "path": "{{inputs.poc_name}}/keys/f5-far-auth-key.tgz"
    },
    {
      "secret_name": "jwt_token",
      "path": "{{inputs.poc_name}}/keys/.jwt"
    }
  ],
  "actions": {
    "run-all-green-scenarios": {
      "title": "Run all green scenarios",
      "description": "Runs every green-rated F5 BNK how-to scenario in dependency order against the deployed cluster; JSON reports land in the PoC reports directory.",
      "rating": "green",
      "steps": [
        {
          "name": "scenario-run-all",
          "args": [
            "ocibnkctl",
            "scenario",
            "run",
            "--all",
            "--poc",
            "/state/{{inputs.poc_name}}"
          ],
          "timeout_seconds": 3600
        }
      ],
      "cleanup_note": "These scenarios left objects on the cluster. Run 'Clean up all scenarios' when done."
    },
    "run-scenario": {
      "title": "Run one scenario",
      "description": "Runs a single green-rated scenario (dependencies must already be satisfied - run bgp-peer-frr first for data-plane scenarios).",
      "rating": "green",
      "inputs": [
        {
          "name": "scenario",
          "type": "string",
          "source": "user",
          "default": "bgp-peer-frr",
          "description": "Scenario name",
          "choices": [
            "bgp-peer-frr",
            "ai-semantic-cache",
            "ai-token-counting",
            "ai-token-counting-dssm",
            "bgp-anycast",
            "cluster-wide-watch",
            "core-file-collection",
            "cwc-admin-access",
            "external-resource-pool",
            "grpc-loadbalance",
            "http-routing-e2e",
            "proxy-protocol-l4",
            "tcp-l4-loadbalance",
            "udp-l4-loadbalance"
          ]
        }
      ],
      "steps": [
        {
          "name": "scenario-run",
          "args": [
            "ocibnkctl",
            "scenario",
            "run",
            "{{inputs.scenario}}",
            "--poc",
            "/state/{{inputs.poc_name}}"
          ],
          "timeout_seconds": 900
        }
      ],
      "cleanup_note": "This scenario left objects on the cluster. Run 'Clean up a scenario' with the same name when done."
    },
    "run-scenario-amber": {
      "title": "Run an amber scenario",
      "description": "Amber-rated: only partially testable in this 2-node demo shape (fic-dynamic-ip needs resources the demo cluster may lack). Expect partial assertions.",
      "rating": "amber",
      "inputs": [
        {
          "name": "scenario",
          "type": "string",
          "source": "user",
          "default": "fic-dynamic-ip",
          "description": "Amber scenario name",
          "choices": [
            "fic-dynamic-ip"
          ]
        }
      ],
      "steps": [
        {
          "name": "scenario-run",
          "args": [
            "ocibnkctl",
            "scenario",
            "run",
            "{{inputs.scenario}}",
            "--poc",
            "/state/{{inputs.poc_name}}"
          ],
          "timeout_seconds": 900
        }
      ],
      "cleanup_note": "This scenario left objects on the cluster. Run 'Clean up a scenario' with the same name when done."
    },
    "clean-scenario": {
      "title": "Clean up a scenario",
      "description": "Deletes the cluster objects a scenario applied.",
      "rating": "green",
      "inputs": [
        {
          "name": "scenario",
          "type": "string",
          "source": "user",
          "default": "tcp-l4-loadbalance",
          "description": "Scenario to clean",
          "choices": [
            "bgp-peer-frr",
            "ai-semantic-cache",
            "ai-token-counting",
            "ai-token-counting-dssm",
            "bgp-anycast",
            "cluster-wide-watch",
            "core-file-collection",
            "cwc-admin-access",
            "external-resource-pool",
            "fic-dynamic-ip",
            "grpc-loadbalance",
            "http-routing-e2e",
            "proxy-protocol-l4",
            "tcp-l4-loadbalance",
            "udp-l4-loadbalance"
          ]
        }
      ],
      "steps": [
        {
          "name": "scenario-clean",
          "args": [
            "ocibnkctl",
            "scenario",
            "clean",
            "{{inputs.scenario}}",
            "--poc",
            "/state/{{inputs.poc_name}}"
          ],
          "timeout_seconds": 600
        }
      ]
    },
    "clean-all-scenarios": {
      "title": "Clean up all scenarios",
      "description": "Removes the cluster objects every green scenario applied, in reverse dependency order (best-effort).",
      "rating": "green",
      "steps": [
        {
          "name": "scenario-clean-all",
          "args": [
            "ocibnkctl",
            "scenario",
            "clean",
            "--all",
            "--poc",
            "/state/{{inputs.poc_name}}"
          ],
          "timeout_seconds": 1200
        }
      ]
    }
  },
  "reports": {
    "dir": "{{inputs.poc_name}}/reports"
  }
}