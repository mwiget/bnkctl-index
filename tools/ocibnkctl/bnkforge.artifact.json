{
  "schema_version": 1,
  "name": "ocibnkctl-tools-runner",
  "version": "2.3.1.4",
  "kind": "container_image",
  "description": "ocibnkctl tools runner (wraps ocibnkctl v2.3.1-1) \u2014 deploys F5 BIG-IP Next for Kubernetes 2.3.1 on a native k3s cluster whose nodes run as sibling containers on the host OCI runtime, reached through the BNK Forge docker-socket proxy. PoC shape is seeded from OCIBNKCTL_* env at init; argv-only steps, no shell.",
  "container_image": {
    "registry_host": "ghcr.io",
    "repository": "mwiget/ocibnkctl-tools-runner",
    "digest": "sha256:7436482ecc98455169c557e9dfda4d4b9980429142a107734e54c94b65017613"
  },
  "lifecycle": {
    "supports_apply": true,
    "supports_destroy": true
  },
  "state": {
    "mount_path": "/state",
    "home_env": {
      "DOCKER_HOST": "tcp://docker-socket-proxy:2375"
    }
  },
  "execution": {
    "engine": "container",
    "limits": {
      "cpus": "2",
      "memory": "2g"
    }
  },
  "steps": {
    "init": [
      {
        "name": "init-poc",
        "args": [
          "ocibnkctl",
          "init",
          "{{inputs.poc_name}}",
          "--no-git"
        ],
        "env": {
          "OCIBNKCTL_CUSTOMER": "{{inputs.customer}}",
          "OCIBNKCTL_PROVIDER": "{{inputs.provider}}",
          "OCIBNKCTL_TMM_NODES": "{{inputs.tmm_nodes}}",
          "OCIBNKCTL_EDGE_OCTET": "{{inputs.edge_octet}}",
          "OCIBNKCTL_HOST_PROFILE": "{{inputs.host_profile}}",
          "OCIBNKCTL_TEEMS_RELAY": "{{inputs.teems_relay}}"
        },
        "timeout_seconds": 300,
        "run_once": true
      }
    ],
    "apply": [
      {
        "name": "validate",
        "args": [
          "ocibnkctl",
          "validate",
          "--poc",
          "/state/{{inputs.poc_name}}"
        ],
        "timeout_seconds": 300
      },
      {
        "name": "e2e",
        "args": [
          "ocibnkctl",
          "e2e",
          "--poc",
          "/state/{{inputs.poc_name}}",
          "--yolo",
          "--confirm-cluster",
          "{{inputs.poc_name}}"
        ],
        "timeout_seconds": 5400,
        "retry": {
          "max_attempts": 2,
          "backoff_seconds": 120
        }
      }
    ],
    "destroy": [
      {
        "name": "destroy",
        "args": [
          "ocibnkctl",
          "destroy",
          "--poc",
          "/state/{{inputs.poc_name}}",
          "--yolo",
          "--confirm-cluster",
          "{{inputs.poc_name}}"
        ],
        "timeout_seconds": 1800
      }
    ]
  },
  "inputs": {
    "required": [
      {
        "name": "poc_name",
        "type": "string",
        "source": "user",
        "default": "poc",
        "description": "PoC/cluster name ([a-z0-9-]). Also names the k3s node containers \u2014 give parallel PoCs on one host distinct names."
      }
    ],
    "optional": [
      {
        "name": "provider",
        "type": "string",
        "source": "user",
        "default": "docker",
        "description": "Host container runtime the k3s nodes run on."
      },
      {
        "name": "tmm_nodes",
        "type": "number",
        "source": "user",
        "default": 1,
        "description": "Worker nodes dedicated to TMM (one active TMM pod each)."
      },
      {
        "name": "edge_octet",
        "type": "number",
        "source": "user",
        "default": 99,
        "description": "3rd octet of the bnk-edge network (192.168.<n>.0/24). Distinct per parallel cluster."
      },
      {
        "name": "host_profile",
        "type": "string",
        "source": "user",
        "default": "",
        "description": "Blank = auto-detect from host cores; 'small' sheds TMM's metrics sidecar."
      },
      {
        "name": "teems_relay",
        "type": "boolean",
        "source": "user",
        "default": false,
        "description": "Host-side TEEMS egress relay for hosts with lossy forwarded egress."
      },
      {
        "name": "customer",
        "type": "string",
        "source": "user",
        "default": "",
        "description": "Optional label recorded in poc.yaml metadata."
      }
    ]
  },
  "references": [],
  "secret_files": [
    {
      "secret_name": "far_tarball",
      "path": "{{inputs.poc_name}}/keys/f5-far-auth-key.tgz"
    },
    {
      "secret_name": "jwt_token",
      "path": "{{inputs.poc_name}}/keys/.jwt"
    }
  ]
}
