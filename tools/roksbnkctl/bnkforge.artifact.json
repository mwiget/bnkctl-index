{
  "schema_version": 1,
  "name": "roksbnkctl-tools-runner",
  "version": "1.20.0.1",
  "kind": "container_image",
  "description": "F5 roksbnkctl tools runner \u2014 provisions a ROKS/IKS cluster and brings up the BNK stack from a single self-contained image. Workspace config is built non-interactively from ROKSBNKCTL_* env vars; procedural steps invoke the artifact's own image via argv only (no shell, no command-string, no image override).",
  "container_image": {
    "registry_host": "ghcr.io",
    "repository": "jgruberf5/roksbnkctl-tools-runner",
    "digest": "sha256:8db5a22ff9eeb0f66f06c6f62c5c5e98437e6b769e8ebea5036a1cd1be0867fc"
  },
  "lifecycle": {
    "supports_apply": true,
    "supports_destroy": true
  },
  "credentials": {
    "cloud": "ibmcloud"
  },
  "state": {
    "mount_path": "/state",
    "home_env": {
      "ROKSBNKCTL_HOME": "/state"
    }
  },
  "execution": {
    "engine": "container",
    "limits": {
      "cpus": "2",
      "memory": "2g"
    }
  },
  "steps": {
    "init": [
      {
        "name": "init",
        "args": [
          "roksbnkctl",
          "init",
          "--non-interactive"
        ],
        "env": {
          "ROKSBNKCTL_REGION": "{{inputs.region}}",
          "ROKSBNKCTL_RESOURCE_GROUP": "{{inputs.resource_group}}",
          "ROKSBNKCTL_PREFIX": "{{inputs.prefix}}",
          "ROKSBNKCTL_CLUSTER_NAME": "{{inputs.cluster_name}}",
          "ROKSBNKCTL_CLUSTER_CREATE": "{{inputs.provision_cluster}}"
        },
        "timeout_seconds": 600,
        "run_once": true
      }
    ],
    "apply": [
      {
        "name": "cluster-up",
        "when": "{{inputs.provision_cluster}}",
        "args": [
          "roksbnkctl",
          "cluster",
          "up",
          "--auto"
        ],
        "timeout_seconds": 3600,
        "retry": {
          "max_attempts": 3,
          "backoff_seconds": 300
        }
      },
      {
        "name": "bnk-up",
        "when": "{{inputs.deploy_bnk}}",
        "args": [
          "roksbnkctl",
          "bnk",
          "up",
          "--auto"
        ],
        "timeout_seconds": 3600,
        "retry": {
          "max_attempts": 2,
          "backoff_seconds": 300
        }
      }
    ],
    "destroy": [
      {
        "name": "down",
        "args": [
          "roksbnkctl",
          "down",
          "--auto"
        ],
        "timeout_seconds": 3600
      }
    ]
  },
  "inputs": {
    "required": [
      {
        "name": "region",
        "type": "string",
        "source": "user",
        "description": "IBM Cloud region for the ROKS/IKS cluster (e.g. us-south)."
      },
      {
        "name": "resource_group",
        "type": "string",
        "source": "user",
        "default": "default",
        "description": "IBM Cloud resource group the workspace resources are created in."
      },
      {
        "name": "prefix",
        "type": "string",
        "source": "user",
        "description": "Resource-name prefix for everything this workspace creates (e.g. acme-eu)."
      },
      {
        "name": "cluster_name",
        "type": "string",
        "source": "user",
        "description": "New cluster name, or an existing cluster name/ID when not provisioning."
      }
    ],
    "optional": [
      {
        "name": "provision_cluster",
        "type": "boolean",
        "source": "user",
        "default": true,
        "description": "true = provision a new ROKS cluster (gates the 'cluster up' step); false = attach to an existing one."
      },
      {
        "name": "deploy_bnk",
        "type": "boolean",
        "source": "user",
        "default": true,
        "description": "Gate for the 'bnk up' step. When false, only the cluster phase runs."
      }
    ]
  },
  "references": []
}
